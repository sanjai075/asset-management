doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title= title ? `${title} - Asset Management System` : 'Asset Management System'
    // Google Fonts
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap", rel="stylesheet")
    // Bootstrap CSS
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    // DataTables CSS
    link(rel="stylesheet", href="https://cdn.datatables.net/1.13.5/css/dataTables.bootstrap5.min.css")
    // Font Awesome Icons
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    // Custom Premium styling
    style.
      body {
        font-family: 'Inter', sans-serif;
        background-color: #f4f6f9;
        color: #333;
      }
      .navbar {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%) !important;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
      }
      .navbar-brand {
        font-weight: 700;
        letter-spacing: 0.5px;
      }
      .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px 0 rgba(0,0,0,0.05);
      }
      .card-header {
        background-color: #fff;
        border-bottom: 1px solid #edf2f7;
        font-weight: 600;
      }
      .table-responsive {
        border-radius: 12px;
      }
      .btn {
        font-weight: 500;
        border-radius: 8px;
        transition: all 0.2s ease;
      }
      .btn:hover {
        transform: translateY(-1px);
      }
      .btn-primary {
        background-color: #2b6cb0;
        border-color: #2b6cb0;
      }
      .btn-primary:hover {
        background-color: #2b5c8f;
        border-color: #2b5c8f;
      }
      /* Custom styles for tables */
      .dataTables_wrapper .dataTables_paginate .paginate_button {
        padding: 0 !important;
        margin: 0 !important;
        border: none !important;
        background: transparent !important;
      }
    block styles

  body
    nav.navbar.navbar-expand-lg.navbar-dark.mb-4
      .container
        a.navbar-brand(href="/")
          i.fa-solid.fa-boxes-stacked.me-2
          | Asset Manager
        button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href="/employees")
                i.fa-solid.fa-users.me-1
                | Employees
            li.nav-item
              a.nav-link(href="/categories")
                i.fa-solid.fa-tags.me-1
                | Categories
            li.nav-item
              a.nav-link(href="/assets")
                i.fa-solid.fa-laptop.me-1
                | Assets
            li.nav-item
              a.nav-link(href="/stock")
                i.fa-solid.fa-chart-pie.me-1
                | Stock View
          ul.navbar-nav.ms-auto
            li.nav-item.dropdown
              a.dropdown-toggle.btn.btn-outline-light.btn-sm.px-3(href="#", id="actionsDropdown", role="button", data-bs-toggle="dropdown", aria-expanded="false")
                i.fa-solid.fa-gears.me-1
                | Actions
              ul.dropdown-menu.dropdown-menu-end(aria-labelledby="actionsDropdown")
                li
                  a.dropdown-item(href="/transactions/issue")
                    i.fa-solid.fa-hand-holding-hand.me-2.text-primary
                    | Issue Asset
                li
                  a.dropdown-item(href="/transactions/return")
                    i.fa-solid.fa-rotate-left.me-2.text-success
                    | Return Asset
                li
                  a.dropdown-item(href="/transactions/scrap")
                    i.fa-solid.fa-trash-can.me-2.text-danger
                    | Scrap Asset

    .container.pb-5
      block content

    // jQuery
    script(src="https://code.jquery.com/jquery-3.7.0.min.js")
    // Bootstrap Bundle JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    // DataTables JS
    script(src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js")
    script(src="https://cdn.datatables.net/1.13.5/js/dataTables.bootstrap5.min.js")
    block scripts
