extends ../layout

block content
  .row.justify-content-center
    .col-md-8
      .card
        .card-header
          h4.mb-0
            i.fa-solid.fa-hand-holding-hand.me-2.text-primary
            | Issue Asset to Employee
        .card-body
          if employees.length === 0
            .alert.alert-warning.mb-0
              i.fa-solid.fa-triangle-exclamation.me-2
              | No active employees available. Please add active employees first.
          else if assets.length === 0
            .alert.alert-warning.mb-0
              i.fa-solid.fa-triangle-exclamation.me-2
              | No available assets in stock. Please add assets or process returns first.
          else
            form.needs-validation(method="POST", action="/transactions/issue", novalidate=true)
              .mb-3
                label.form-label Select Employee (Active Only) #[span.text-danger *]
                select.form-select(name="employeeId", required=true)
                  option(value="" disabled=true selected=true) -- Select Employee --
                  each emp in employees
                    option(value=emp.id)= `${emp.name} (${emp.employeeCode}) - ${emp.branch || 'No Branch'}`
                .invalid-feedback Please select an active employee.

              .mb-3
                label.form-label Select Available Asset #[span.text-danger *]
                select.form-select(name="assetId", required=true)
                  option(value="" disabled=true selected=true) -- Select Asset --
                  each asset in assets
                    option(value=asset.id)= `${asset.assetCode} - ${asset.make} ${asset.model} (S/N: ${asset.serialNumber}) [${asset.category ? asset.category.name : 'N/A'}]`
                .invalid-feedback Please select an available asset to issue.

              .mb-3
                label.form-label Notes / Remarks
                textarea.form-control(name="notes", rows="3", placeholder="e.g. Issued for Project Alpha, include charging cables...")

              .d-flex.justify-content-between.mt-4
                a.btn.btn-secondary(href="/assets") Cancel
                button.btn.btn-primary(type="submit")
                  i.fa-solid.fa-check.me-1
                  | Process Issuance

block scripts
  script.
    (function () {
      'use strict'
      var forms = document.querySelectorAll('.needs-validation')
      Array.prototype.slice.call(forms)
        .forEach(function (form) {
          form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
              event.preventDefault()
              event.stopPropagation()
            }
            form.classList.add('was-validated')
          }, false)
        })
    })()
