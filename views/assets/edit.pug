extends ../layout

block content
  .row.justify-content-center
    .col-md-8
      .card
        .card-header
          h4.mb-0 Edit Asset
        .card-body
          form.needs-validation(method="POST", action=`/assets/edit/${asset.id}`, novalidate=true)
            .mb-3
              label.form-label Category #[span.text-danger *]
              select.form-select(name="categoryId", required=true)
                each cat in categories
                  option(value=cat.id selected=(asset.categoryId == cat.id))= cat.name
              .invalid-feedback Please select an asset category.

            .row
              .col-md-6.mb-3
                label.form-label Asset Code #[span.text-danger *]
                input.form-control(type="text", name="assetCode", value=asset.assetCode, required=true)
                .invalid-feedback Please enter a unique Asset Code.
              .col-md-6.mb-3
                label.form-label Serial Number #[span.text-danger *]
                input.form-control(type="text", name="serialNumber", value=asset.serialNumber, required=true)
                .invalid-feedback Please enter a unique Serial Number.

            .row
              .col-md-6.mb-3
                label.form-label Make #[span.text-danger *]
                input.form-control(type="text", name="make", value=asset.make, required=true)
                .invalid-feedback Please enter the manufacturer/make.
              .col-md-6.mb-3
                label.form-label Model #[span.text-danger *]
                input.form-control(type="text", name="model", value=asset.model, required=true)
                .invalid-feedback Please enter the model name.

            .row
              .col-md-6.mb-3
                label.form-label Purchase Date #[span.text-danger *]
                input.form-control(type="date", name="purchaseDate", value=asset.purchaseDate, required=true)
                .invalid-feedback Please select a valid purchase date.
              .col-md-6.mb-3
                label.form-label Purchase Value (₹) #[span.text-danger *]
                input.form-control(type="number", step="0.01", name="value", value=asset.value, required=true)
                .invalid-feedback Please enter a valid numeric purchase value.

            .mb-3
              label.form-label Current Location / Branch #[span.text-danger *]
              input.form-control(type="text", name="branch", value=asset.branch, required=true)
              .invalid-feedback Please specify the current location or branch.

            .mb-3
              label.form-label Current Status
              input.form-control(type="text", value=asset.status, disabled=true)
              small.text-muted Asset status is managed via Issue, Return, and Scrap transaction actions.

            .d-flex.justify-content-between.mt-4
              a.btn.btn-secondary(href="/assets") Cancel
              button.btn.btn-primary(type="submit")
                i.fa-solid.fa-floppy-disk.me-1
                | Update Asset

block scripts
  script.
    (function () {
      'use strict'
      var forms = document.querySelectorAll('.needs-validation')
      Array.prototype.slice.call(forms)
        .forEach(function (form) {
          form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
              event.preventDefault()
              event.stopPropagation()
            }
            form.classList.add('was-validated')
          }, false)
        })
    })()
